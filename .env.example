NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Project origin only; do not include /rest/v1.
NEXT_PUBLIC_SUPABASE_URL=https://lqoqxalmimpmrmlqcaft.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — never prefix with NEXT_PUBLIC_. Used by Stripe webhooks and /api/admin/* routes.
# Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# Set to true after running supabase/rls-policies.sql in the SQL Editor (optional; launch page auto-checks)
SUPABASE_RLS_APPLIED=
SUPABASE_INDEXES_APPLIED=
SUPABASE_LEAKED_PASSWORD_PROTECTION_ENABLED=

# Optional — direct Postgres URI for CLI/scripts (Dashboard → Database → Connection string)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

STRIPE_MODE=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRODUCT_PRO=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
# Set true after Stripe Tax is configured for one-time product orders.
STRIPE_PRODUCT_AUTOMATIC_TAX_ENABLED=
STRIPE_WEBHOOK_TEST_ENABLED=

