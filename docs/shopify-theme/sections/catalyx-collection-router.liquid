{% comment %}
  Catalyx collection router.
  Use on collection templates to expose local app routes and core collection links.
{% endcomment %}

<section class="catalyx-collection-router" data-section-id="{{ section.id }}">
  <div class="catalyx-collection-router__inner">
    <div>
      <p class="catalyx-collection-router__eyebrow">Catalyx storefront</p>
      <h2 class="catalyx-collection-router__title">
        {{ collection.title | default: 'Catalyx nutrients' }}
      </h2>
      {% if collection.description != blank %}
        <div class="catalyx-collection-router__copy">{{ collection.description }}</div>
      {% else %}
        <p class="catalyx-collection-router__copy">
          Browse the Catalyx nutrient range by base system, stage additives, and specialist support products.
        </p>
      {% endif %}
    </div>

    <nav class="catalyx-collection-router__nav" aria-label="Catalyx collection navigation">
      <a href="/collections/all">All products</a>
      <a href="/collections/core-nutrients">Core nutrients</a>
      <a href="/collections/additives">Additives</a>
      <a href="/collections/specialist">Specialist</a>
      <a href="/pages/feed-chart">Feed chart</a>
      <a href="/pages/product-guide">Product guide</a>
      <a href="/pages/safety-storage">Safety</a>
    </nav>
  </div>
</section>

{% stylesheet %}
  .catalyx-collection-router {
    background: #050707;
    color: #f8fafc;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .catalyx-collection-router__inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 42px 20px 26px;
  }

  .catalyx-collection-router__eyebrow {
    margin: 0 0 10px;
    color: #c8f500;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .catalyx-collection-router__title {
    margin: 0;
    color: #fff;
    font-size: clamp(34px, 6vw, 64px);
    font-weight: 950;
    line-height: 0.98;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .catalyx-collection-router__copy {
    max-width: 760px;
    margin-top: 16px;
    color: #a1a1aa;
    font-size: 16px;
    line-height: 1.65;
  }

  .catalyx-collection-router__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 26px;
  }

  .catalyx-collection-router__nav a {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 6px;
    padding: 10px 13px;
    background: rgba(255, 255, 255, 0.04);
    color: #d4d4d8;
    font-size: 12px;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .catalyx-collection-router__nav a:hover {
    border-color: rgba(200, 245, 0, 0.6);
    color: #d9ff34;
  }

  @media (max-width: 720px) {
    .catalyx-collection-router__nav a {
      width: 100%;
      text-align: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Catalyx collection router",
  "settings": [],
  "presets": [
    {
      "name": "Catalyx collection router"
    }
  ]
}
{% endschema %}
