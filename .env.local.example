# Catalyx Labs — example env for local development
# Copy this file to .env.local and fill values needed for production features.

# Site URL (used for redirects and Stripe return URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase client (public) — required for Supabase-enabled features
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — required for server-side admin operations (webhooks)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe keys for production checkout and webhooks
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Optional: toggle debug features
# NEXT_PUBLIC_DEBUG=true
