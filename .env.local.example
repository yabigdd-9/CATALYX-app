# Catalyx Labs — example env for local development
# Copy this file to .env.local and fill values needed for production features.

# Site URL (used for redirects and Stripe return URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase client (public) — safe for browser / client components
# Project origin only; do not include /rest/v1.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (SERVER ONLY) — Stripe webhooks + admin API routes
# Do NOT expose in client code or NEXT_PUBLIC_ variables.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_RLS_APPLIED=
SUPABASE_INDEXES_APPLIED=
SUPABASE_LEAKED_PASSWORD_PROTECTION_ENABLED=

# Stripe keys for production checkout and webhooks
STRIPE_MODE=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Catalyx Pro Product and recurring Price IDs from Stripe -> Products.
STRIPE_PRODUCT_PRO=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
# Set true after Stripe Tax is configured for one-time product orders.
STRIPE_PRODUCT_AUTOMATIC_TAX_ENABLED=
STRIPE_WEBHOOK_TEST_ENABLED=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=

# Optional: toggle debug features
# NEXT_PUBLIC_DEBUG=true
